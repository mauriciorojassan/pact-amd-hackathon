# Pact Configuration
# Copy to .env and fill in your values. Never commit .env or .env.local.

# Fireworks AI API (required for Fireworks routing)
FIREWORKS_API_KEY=fw_3a_example_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Local inference (optional — set PACT_LOCAL_AVAILABLE=0 to disable)
PACT_LOCAL_AVAILABLE=1
PACT_LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct
PACT_LOCAL_BASE_URL=http://localhost:8000/v1

# Judge model (even smaller, for output quality checks)
PACT_JUDGE_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Routing thresholds
PACT_TRIAGE_CONFIDENCE=0.7
PACT_JUDGE_CONFIDENCE=0.6
PACT_MAX_ESCALATIONS=2

# Fireworks model endpoints
PACT_FW_CHEAP=accounts/fireworks/models/llama-v3p2-3b-instruct
PACT_FW_MEDIUM=accounts/fireworks/models/llama-v3p1-8b-instruct
PACT_FW_POWERFUL=accounts/fireworks/models/llama-v3p1-405b-instruct

# Development mode (no GPU, mock responses)
PACT_MOCK=0
