# Pact Configuration
# Copy to secrets/env and fill in your values:
#   cp .env.example secrets/env
#   nano secrets/env   # add your API key
#
# The CLI auto-loads secrets/env when present.

# ── Fireworks AI (required) ─────────────────────────────────────────────
FIREWORKS_API_KEY=fw_3a_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── Model routing tiers ─────────────────────────────────────────────────
PACT_FW_CHEAP=accounts/fireworks/models/gpt-oss-120b
PACT_FW_MEDIUM=accounts/fireworks/models/kimi-k2p6
PACT_FW_POWERFUL=accounts/fireworks/models/deepseek-v4-pro

# ── Local inference (optional, needs AMD GPU + ROCm) ────────────────────
PACT_LOCAL_AVAILABLE=0
PACT_LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct
PACT_LOCAL_BASE_URL=http://localhost:8000/v1

# ── Routing ─────────────────────────────────────────────────────────────
PACT_MAX_ESCALATIONS=3
PACT_LOG=WARNING

# ── Dev mode (no GPU, no API key) ───────────────────────────────────────
# PACT_MOCK=1
